# Server Configuration
PORT=10000
NODE_ENV=production

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/team_iran_vs_usa
DB_HOST=localhost
DB_PORT=5432
DB_NAME=team_iran_vs_usa
DB_USER=username
DB_PASSWORD=password

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# TON Blockchain Configuration
TON_API_ENDPOINT=https://toncenter.com/api/v2/jsonRPC
TON_API_KEY=your_ton_api_key_here

# WIN Token Configuration
WIN_TOKEN_CONTRACT_ADDRESS=your_win_token_contract_address
WIN_TOTAL_SUPPLY=1000000000000

# Treasury Configuration
TREASURY_CONTRACT_ADDRESS=your_treasury_contract_address
SUPER_ADMIN_WALLET=your_super_admin_wallet_address

# Game Configuration
TAP_REWARD=5
MAX_TAPS_PER_MINUTE=60
PVP_MIN_WAGER=100
REFERRAL_BONUS=50

# Security
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
