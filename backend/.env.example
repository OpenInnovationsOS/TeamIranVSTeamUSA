# Server Configuration
PORT=3001
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/team-iran-vs-usa

# Supabase Configuration (for compatibility)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_make_it_long_and_secure
JWT_EXPIRES_IN=7d

# TON Blockchain Configuration
TON_ADMIN_WALLET=0:your_admin_wallet_address_here
STG_TOKENS_WALLET=0:your_stg_tokens_wallet_address_here
PREMIUM_FEATURES_WALLET=0:your_premium_features_wallet_address_here
TON_API_KEY=your_ton_api_key_here
TON_API_ENDPOINT=https://toncenter.com/api/v2/jsonRPC

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Railway Configuration (for deployment)
RAILWAY_ENVIRONMENT=production
RAILWAY_PUBLIC_DOMAIN=https://your-app.railway.app

# Development Settings
DEBUG=team-iran-vs-usa:*
LOG_LEVEL=info
