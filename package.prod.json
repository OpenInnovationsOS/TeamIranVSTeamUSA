{
  "name": "team-iran-vs-usa-production",
  "version": "1.0.0",
  "description": "Production build configuration for Team Iran vs USA Telegram Game",
  "main": "dist/server-enhanced.js",
  "scripts": {
    "dev": "NODE_ENV=development node src/server-enhanced.js",
    "build": "npm run build:client && npm run build:server",
    "build:client": "NODE_ENV=production webpack --config webpack.prod.config.js",
    "build:server": "NODE_ENV=production babel src/server-enhanced.js -o dist/server-enhanced.js",
    "start": "NODE_ENV=production node dist/server-enhanced.js",
    "start:cluster": "NODE_ENV=production node dist/cluster-server.js",
    "test": "NODE_ENV=test jest --coverage",
    "test:watch": "NODE_ENV=test jest --watch --coverage",
    "test:e2e": "playwright test",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint src --ext .js,.jsx,.ts,.tsx --fix",
    "analyze": "webpack-bundle-analyzer dist/static/js/*.js",
    "migrate": "node scripts/migrate.js",
    "seed": "node scripts/seed.js",
    "backup": "node scripts/backup.js",
    "deploy": "npm run build && npm run deploy:staging",
    "deploy:staging": "rsync -avz --delete dist/ staging@server:/var/www/team-iran-vs-usa/",
    "deploy:production": "rsync -avz --delete dist/ production@server:/var/www/team-iran-vs-usa/",
    "docker:build": "docker build -t team-iran-vs-usa:latest .",
    "docker:run": "docker run -p 3000:3000 -e NODE_ENV=production team-iran-vs-usa:latest",
    "docker:compose": "docker-compose up -d",
    "performance": "node scripts/performance-test.js",
    "security": "node scripts/security-audit.js",
    "monitor": "node scripts/monitor.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "@ton/core": "^0.63.1",
    "@ton/crypto": "^3.3.0",
    "@ton/ton": "^16.2.2",
    "@tonconnect/sdk": "^3.0.3",
    "axios": "^1.6.2",
    "bcrypt": "^5.1.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "sqlite3": "^5.1.6",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^9.2.3",
    "node-telegram-bot-api": "^0.64.0",
    "pg": "^8.11.3",
    "redis": "^4.6.10",
    "ton-core": "^0.53.0",
    "ton-crypto": "^3.2.0",
    "uuid": "^9.0.1",
    "ws": "^8.14.2",
    "cluster": "^0.7.7",
    "pm2": "^5.3.0",
    "winston": "^3.8.2",
    "morgan": "^1.10.0",
    "express-validator": "^6.15.0",
    "express-slow-down": "^1.6.0",
    "express-mongo-sanitize": "^2.2.0",
    "hpp": "^0.2.3",
    "xss": "^1.0.14"
  },
  "devDependencies": {
    "@babel/cli": "^7.22.0",
    "@babel/core": "^7.22.0",
    "@babel/preset-env": "^7.22.0",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.0",
    "webpack-bundle-analyzer": "^4.9.0",
    "babel-loader": "^9.1.0",
    "css-loader": "^6.8.0",
    "style-loader": "^3.3.0",
    "file-loader": "^6.2.0",
    "url-loader": "^4.1.0",
    "html-webpack-plugin": "^5.5.0",
    "mini-css-extract-plugin": "^2.7.0",
    "optimize-css-assets-webpack-plugin": "^6.0.1",
    "terser-webpack-plugin": "^5.3.0",
    "clean-webpack-plugin": "^4.0.0",
    "copy-webpack-plugin": "^11.0.0",
    "workbox-webpack-plugin": "^6.6.0",
    "jest": "^29.5.0",
    "playwright": "^1.35.0",
    "eslint": "^8.44.0",
    "eslint-config-prettier": "^8.8.0",
    "prettier": "^3.0.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/jest-dom": "^5.16.0",
    "nodemon": "^3.0.1",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "rimraf": "^5.0.1"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ]
}
